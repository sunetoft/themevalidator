generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            String          @default("user") // "admin" | "user"
  stripeCustomerId String?        // set on first Stripe checkout
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  accounts        Account[]
  paperTrades     PaperTrade[]
  sessions        Session[]
  subscription    Subscription?
  theses          Thesis[]
  tradeStrategies TradeStrategy[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Theme {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  iconUrl     String?
  isPublic    Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  theses      Thesis[]

  @@index([isPublic])
  @@index([createdAt])
}

model Thesis {
  id               String          @id @default(cuid())
  userId           String
  themeId          String?
  title            String
  description      String
  inputType        String
  sourceUrl        String?
  sourceText       String?
  pdfPath          String?
  pdfIsPublic      Boolean         @default(false)
  overallScore     Int?
  sentimentScore   Int?
  ecosystemScore   Int?
  riskScore        Int?
  opportunityScore Int?
  moatScore        Int?
  status           String          @default("pending")
  isPublic         Boolean         @default(false) // thesis visible on its own (kept for backward compat)
  publishedAt      DateTime?
  sentimentData    Json?
  ecosystemData    Json?
  externalFactors  Json?
  bottlenecks      Json?
  valuationData    Json?
  financialData    Json?    // Real metrics from yfinance: per-ticker P/E, PEG, growth, margins
  technicalData    Json?    // Per-ticker RSI, MA50/200, trend classification
  earningsData     Json?    // Per-ticker earnings beat/miss history, next earnings date
  themeEtfs        Json?    // ETFs covering the theme: symbol, name, AUM, YTD, overlap
  graphSyncedAt    DateTime?       // When this thesis was last synced to FalkorDB graph
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  paperTrades      PaperTrade[]
  basketMembers     BasketMember[]
  thesisAlerts     ThesisAlert[]
  theme            Theme?          @relation(fields: [themeId], references: [id], onDelete: SetNull)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeStrategies  TradeStrategy[]

  @@index([userId])
  @@index([themeId])
  @@index([status])
  @@index([createdAt])
}

model TradeStrategy {
  id              String       @id @default(cuid())
  thesisId        String
  userId          String
  name            String?
  amount          Float
  riskProfile     String
  answers         Json
  generatedPrompt String
  strategy        String?
  status          String       @default("pending")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  paperTrades     PaperTrade[]
  thesis          Thesis       @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([thesisId])
  @@index([userId])
}

model PaperTrade {
  id             String          @id @default(cuid())
  strategyId     String
  thesisId       String
  userId         String
  name           String?
  initialCapital Float
  currentCash    Float
  totalValue     Float           @default(0)
  pnl            Float           @default(0)
  pnlPercent     Float           @default(0)
  status         String          @default("active")
  lastCheckedAt  DateTime?
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orders         PaperOrder[]
  positions      PaperPosition[]
  snapshots      PaperTradeSnapshot[]
  strategy       TradeStrategy   @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  thesis         Thesis          @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeLog       PaperTradeLog[]

  @@index([strategyId])
  @@index([thesisId])
  @@index([userId])
  @@index([status])
}

model PaperOrder {
  id           String     @id @default(cuid())
  paperTradeId String
  ticker       String
  side         String
  orderType    String
  targetPrice  Float
  quantity     Float
  filledPrice  Float?
  status       String     @default("pending")
  notes        String?
  filledAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  paperTrade   PaperTrade @relation(fields: [paperTradeId], references: [id], onDelete: Cascade)

  @@index([paperTradeId])
  @@index([ticker])
  @@index([status])
}

model PaperPosition {
  id            String     @id @default(cuid())
  paperTradeId  String
  ticker        String
  quantity      Float
  avgCostBasis  Float
  currentPrice  Float      @default(0)
  marketValue   Float      @default(0)
  unrealizedPnl Float      @default(0)
  lastUpdatedAt DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  paperTrade    PaperTrade @relation(fields: [paperTradeId], references: [id], onDelete: Cascade)

  @@unique([paperTradeId, ticker])
  @@index([paperTradeId])
}

model PaperTradeLog {
  id            String     @id @default(cuid())
  paperTradeId  String
  action        String
  ticker        String?
  details       String
  priceAtAction Float?
  createdAt     DateTime   @default(now())
  paperTrade    PaperTrade @relation(fields: [paperTradeId], references: [id], onDelete: Cascade)

  @@index([paperTradeId])
  @@index([createdAt])
}

model PaperTradeSnapshot {
  id            String   @id @default(cuid())
  paperTradeId  String
  totalValue    Float
  pnl           Float
  pnlPercent    Float
  positions     Json     // { "TICKER": { marketValue, unrealizedPnl, quantity } }
  createdAt     DateTime @default(now())
  paperTrade    PaperTrade @relation(fields: [paperTradeId], references: [id], onDelete: Cascade)

  @@index([paperTradeId])
  @@index([createdAt])
}

model BasketMember {
  id              String   @id @default(cuid())
  thesisId        String
  ticker          String?
  companyName     String
  role            String?
  competency      String?
  moatRating      Int?
  valuationStatus String?
  marketCap       String?
  peRatio         String?
  instrumentType  String?  @default("stock") // "stock" | "etf"
  sector          String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  thesis          Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
  @@index([ticker])
  @@map("ThemeMember")
}

model PasswordReset {
  token     String   @id
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique
  stripeSubscriptionId  String   @unique
  stripePriceId         String
  stripeCustomerId      String
  tier                  String   @default("single") // single plan, kept for extensibility
  status                String   @default("active") // active, canceled, past_due, trialing
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ThesisAlert {
  id          String   @id @default(cuid())
  thesisId    String
  type        String   // earnings_beat, earnings_miss, guidance_cut, price_surge, price_drop,
                       // technical_breakdown, technical_breakout, news_positive, news_negative,
                       // valuation_stretch, analyst_upgrade, analyst_downgrade, thesis_confirmation
  severity    String   @default("warning") // critical, warning, info, positive
  ticker      String?
  title       String
  description String
  data        Json?    // Structured payload with the specific metrics that triggered the alert
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  thesis      Thesis   @relation(fields: [thesisId], references: [id], onDelete: Cascade)

  @@index([thesisId])
  @@index([type])
  @@index([severity])
  @@index([createdAt])
}
